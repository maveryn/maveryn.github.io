{% if site.bib_search %}
  <script src="{{ '/assets/js/bibsearch.js' | relative_url | bust_file_cache }}" type="module"></script>
  <div class="bib-filter">
    <label class="bib-filter-label" for="bibsearch">Filter publications</label>
    <input
      type="text"
      id="bibsearch"
      spellcheck="false"
      autocomplete="off"
      class="search bibsearch-form-input"
      placeholder="Search titles and abstracts"
    >
  </div>
{% endif %}
